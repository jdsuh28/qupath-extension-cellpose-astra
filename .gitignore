# ================================
# ASTRA extension fork .gitignore
# ================================
# Purpose:
# Exclude OS artifacts, IDE/editor metadata, build outputs, local runtime noise,
# and local Python environment artifacts.
# Keep extension source, vendored ASTRA resources, workflows, Python source,
# and Gradle wrapper files tracked.

# ----------------
# OS artifacts
# ----------------
.DS_Store
._*
Thumbs.db
desktop.ini

# ----------------
# IDE / editor metadata
# ----------------
.idea/
*.iml
*.iws
out/
.vscode/
.settings/
.project
.classpath

# ----------------
# Gradle / build artifacts
# ----------------
.gradle/
build/
target/
bin/
docs/
deploy/
out/

# ----------------
# Keep tracked Gradle wrapper files
# ----------------
!gradlew
!gradlew.bat
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# ----------------
# Logs / temp / crash files
# ----------------
log/
logs/
*.log
hs_err*.log
*.tmp
*.temp
*.bak
*.swp
*~

# ----------------
# Local runtime / scratch data
# ----------------
data/
/data/

# ----------------
# Python local artifacts
# Keep .py source files tracked.
# ----------------
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.venv/
venv/
env/
