  "miniforge": {
    "version": "26.3.2-3",
    "installRoot": "~/.astra/miniforge",
    "downloadRoot": "~/.astra/downloads/miniforge",
    "platforms": {
      "macos-arm64": {
        "installerType": "sh",
        "fileName": "Miniforge3-MacOSX-arm64.sh",
