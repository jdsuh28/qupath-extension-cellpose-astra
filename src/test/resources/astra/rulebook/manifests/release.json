    "baseRef": "0cac592dcdc2c71a97c0b95f72dbb3ef151e4c7b",
    "targetBranch": "main",
    "releaseTag": "${astra_tag}"
  },
  "cellposeAstra": {
    "repo": "jdsuh28/cellpose-astra",
    "baseRef": "v4.1.1+astra.3",
    "pythonVersion": "3.10",
    "runtimePins": {
      "numpy": "1.26.4",
      "torch": "2.2.2",
      "torchvision": "0.17.2",
      "opencv-python-headless": "4.10.0.84",
      "scipy": "1.15.3",
      "natsort": "8.4.0",
      "tifffile": "2025.5.10",
      "tqdm": "4.68.3",
      "fastremap": "1.20.0",
      "imagecodecs": "2025.3.30",
      "roifile": "2025.12.12",
      "fill-voids": "2.1.2",
      "segment-anything": "1.0",
      "pillow": "12.2.0",
      "typing-extensions": "4.15.0",
      "filelock": "3.29.4",
      "fsspec": "2026.6.0",
